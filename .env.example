# Local development defaults
# Example local Postgres URL if you run a Docker/Postgres instance on 127.0.0.1:55432.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:55432/attestly_dev?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:55432/attestly_dev?schema=public"
BLOB_STORAGE_BACKEND="mock"
BLOB_MOCK_ROOT="./.blob-mock"
AUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="replace-me"
GOOGLE_CLIENT_SECRET="replace-me"

# Vercel + Neon production notes
# - DATABASE_URL should be the pooled Neon URL used by the app runtime
# - DIRECT_DATABASE_URL should be the direct Neon URL used for deploy-time migrations
# - BLOB_STORAGE_BACKEND must be "vercel-blob" in production
# - BLOB_READ_WRITE_TOKEN must come from Vercel Blob
# - NEXTAUTH_URL must match the deployed app origin used in Google OAuth
#
# Example:
# DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require"
# BLOB_STORAGE_BACKEND="vercel-blob"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# NEXTAUTH_URL="https://app.attestly.example"
